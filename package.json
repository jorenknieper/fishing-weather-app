{
  "name": "fishing-weather-app",
  "version": "0.0.0",
  "private": true,
  "description": "Static GitHub Pages weather dashboard for anglers in Aalter, Belgium.",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "lint": "eslint --cache --no-error-on-unmatched-pattern \"app.js\" \"js/**/*.js\" \"scripts/**/*.js\"",
    "lint:fix": "eslint --cache --fix --no-error-on-unmatched-pattern \"app.js\" \"js/**/*.js\" \"scripts/**/*.js\"",
    "lint:css": "stylelint \"style.css\"",
    "lint:css:fix": "stylelint --fix \"style.css\"",
    "format": "prettier --write \"**/*.{js,css,html,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,css,html,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.3.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0"
  }
}
